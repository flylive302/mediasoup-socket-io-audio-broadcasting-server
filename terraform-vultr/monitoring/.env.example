# Copy to `.env` (gitignored) and fill in. Consumed by docker-compose.yml.

# The app's internal key — MUST match prod.tfvars `laravel_internal_key`.
# Alloy sends it as the X-Internal-Key header so /metrics/prometheus returns 200.
LARAVEL_INTERNAL_KEY=

# Grafana Cloud hosted-Prometheus remote_write endpoint + credentials.
# Grafana Cloud → Connections → Prometheus → "Sending metrics ... remote_write".
# TOKEN = a Cloud Access Policy token scoped to metrics:write (NOT your login).
GRAFANA_CLOUD_URL=https://prometheus-prod-XX-region.grafana.net/api/prom/push
GRAFANA_CLOUD_USER=
GRAFANA_CLOUD_TOKEN=
