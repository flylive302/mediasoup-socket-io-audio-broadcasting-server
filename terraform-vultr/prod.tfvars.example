# =============================================================================
# FlyLive Audio (Vultr) — PRODUCTION var file (template)
# =============================================================================
# Usage (production Vultr account — SEPARATE account from staging):
#   cp prod.tfvars.example prod.tfvars            # then fill in the secrets
#   export VULTR_API_KEY=<production account PAT>
#   terraform plan  -var-file=prod.tfvars -out=tfplan
#   terraform apply tfplan
#
# prod.tfvars is gitignored (contains secrets). This .example is committed.
# Secrets must EQUAL the PRODUCTION Laravel Cloud env vars, and must be FRESHLY
# ROTATED at cutover (slice J) — never the old AWS plaintext values:
#   laravel_internal_key == Laravel MSAB_INTERNAL_KEY (production)
#   jwt_secret           == Laravel MSAB_JWT_SECRET   (production)
# =============================================================================

# --- Environment-specific (non-secret) ---
environment     = "production"
audio_domain    = "audio.flyliveapp.com"
cors_origins    = "https://flyliveapp.com,https://app.flyliveapp.com,https://localhost,capacitor://localhost"  # localhost origins = Capacitor native shell (Android https://localhost, iOS capacitor://localhost)
laravel_api_url = "https://app.flyliveapp.com"

# --- Region fleet (slice 06: full 3-region fleet; >= 2 per region for HA) ---
# Each entry deploys a complete stack in that region (its fixed multi-instance
# fleet behind its own LB).
fleet_regions = {
  bom = 2
  fra = 2
  sgp = 2
}
instance_plan = "vhf-2c-4gb"
# Frankfurt (fra) has NO High Frequency (vhf) line — override per-region for any
# region that lacks the default plan (unset regions use instance_plan above):
# region_instance_plans = { fra = "voc-g-4c-16gb-80s-amd" }

# --- State-migration anchor (retained; not a deploy toggle) ---
# The region slices 04/05 first applied — the moved-block key that re-homes the
# live single-region state to the keyed for_each. Must be a key of fleet_regions.
tracer_region   = "bom"

# --- Per-region LB hostnames (slice 06) ---
# Left unset → each region derives `<city>.audio.flyliveapp.com`
# (mumbai/frankfurt/singapore), the exact hosts config/realtime.php resolves Rooms
# to. Override only for non-conventional hosts:
# region_hostnames = { bom = "mumbai.audio.flyliveapp.com" }

image_tag       = "CHANGE_ME_sha-<commit8>"   # from the ghcr-publish.yml CI run, never "latest"
ghcr_pull_token = "CHANGE_ME_classic_PAT_read:packages_only"

# --- Secrets (generate with: openssl rand -hex 32; ROTATE at cutover) ---
jwt_secret           = "CHANGE_ME_64_hex"
laravel_internal_key = "CHANGE_ME_64_hex"
session_secret       = "CHANGE_ME_64_hex"

# --- Cloudflare Realtime TURN (prod key from Cloudflare dashboard) ---
cloudflare_turn_api_key = "CHANGE_ME"
cloudflare_turn_key_id  = "CHANGE_ME"

# --- Broadcast HLS tier (realtime-09) — optional, defaults to disabled ---
# broadcast_hls_enabled    = true
# hls_r2_endpoint          = "https://<acct>.r2.cloudflarestorage.com"
# hls_r2_bucket            = "flylive-live-hls"
# hls_public_base_url      = "https://live.flyliveapp.com"
# hls_r2_access_key_id     = "CHANGE_ME"
# hls_r2_secret_access_key = "CHANGE_ME"

# --- Load balancer TLS (Cloudflare Origin CA — NOT Vultr auto_ssl_domain; that
# requires a Vultr-hosted DNS zone, which conflicts with keeping Cloudflare as
# DNS authority). PREREQUISITE (operator-generated): in the Cloudflare dashboard,
# Websites -> flyliveapp.com -> SSL/TLS -> Origin Server -> Create Certificate, for
# a WILDCARD `*.audio.flyliveapp.com` — one cert covers all three regional LB
# hostnames (mumbai/frankfurt/singapore). The Cloudflare DNS record for EACH
# regional hostname MUST be proxied (orange-cloud) — Origin CA certs are only
# trusted by Cloudflare's edge, not public browsers directly. ---
lb_ssl_certificate = "CHANGE_ME_PEM_CERT"
lb_ssl_private_key = "CHANGE_ME_PEM_PRIVATE_KEY"
# lb_ssl_chain      = "CHANGE_ME_PEM_CHAIN"   # optional
