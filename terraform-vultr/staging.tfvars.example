# =============================================================================
# FlyLive Audio (Vultr) — STAGING var file (template)
# =============================================================================
# Usage (staging Vultr account):
#   cp staging.tfvars.example staging.tfvars      # then fill in the secrets
#   export VULTR_API_KEY=<staging account PAT>
#   terraform plan  -var-file=staging.tfvars -out=tfplan
#   terraform apply tfplan
#
# staging.tfvars is gitignored (contains secrets). This .example is committed.
# Secrets must EQUAL the STAGING Laravel Cloud env vars:
#   laravel_internal_key == Laravel MSAB_INTERNAL_KEY (staging)
#   jwt_secret           == Laravel MSAB_JWT_SECRET   (staging)
# =============================================================================

# --- Environment-specific (non-secret) ---
environment     = "staging"
audio_domain    = "audio.staging.flyliveapp.com"
cors_origins    = "https://staging.flyliveapp.com,https://app.staging.flyliveapp.com"
laravel_api_url = "https://app.staging.flyliveapp.com"

# --- Region fleet (faithful 3-region replica; drop counts to 1 between test cycles) ---
fleet_regions = {
  bom = 2
  fra = 2
  sgp = 2
}
instance_plan = "vhf-2c-4gb"

# --- Slice D: single-region tracer ---
tracer_region   = "bom"
image_tag       = "CHANGE_ME_sha-<commit8>"   # from the ghcr-publish.yml CI run, never "latest"
ghcr_pull_token = "CHANGE_ME_classic_PAT_read:packages_only"

# --- Secrets (generate with: openssl rand -hex 32) ---
jwt_secret           = "CHANGE_ME_64_hex"
laravel_internal_key = "CHANGE_ME_64_hex"
session_secret       = "CHANGE_ME_64_hex"

# --- Cloudflare Realtime TURN (staging key from Cloudflare dashboard) ---
cloudflare_turn_api_key = "CHANGE_ME"
cloudflare_turn_key_id  = "CHANGE_ME"

# --- Broadcast HLS tier (realtime-09) — optional, defaults to disabled ---
# broadcast_hls_enabled    = true
# hls_r2_endpoint          = "https://<acct>.r2.cloudflarestorage.com"
# hls_r2_bucket            = "flylive-live-hls-staging"
# hls_public_base_url      = "https://live.staging.flyliveapp.com"
# hls_r2_access_key_id     = "CHANGE_ME"
# hls_r2_secret_access_key = "CHANGE_ME"

# --- Load balancer TLS (Cloudflare Origin CA — NOT Vultr auto_ssl_domain; that
# requires a Vultr-hosted DNS zone, which conflicts with keeping Cloudflare as
# DNS authority). Generate in Cloudflare dashboard: Websites -> the zone ->
# SSL/TLS -> Origin Server -> Create Certificate, for tracer_region.audio_domain
# (or a wildcard). The Cloudflare DNS record for that hostname MUST be proxied
# (orange-cloud) — Origin CA certs are only trusted by Cloudflare's edge, not
# public browsers directly. ---
lb_ssl_certificate = "CHANGE_ME_PEM_CERT"
lb_ssl_private_key = "CHANGE_ME_PEM_PRIVATE_KEY"
# lb_ssl_chain      = "CHANGE_ME_PEM_CHAIN"   # optional
