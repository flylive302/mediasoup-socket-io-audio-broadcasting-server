# =============================================================================
# Terraform state backend — PRODUCTION (Vultr Object Storage, S3-compatible)
# =============================================================================
# Same as staging but in the SEPARATE production Vultr account — a destructive
# staging apply physically cannot touch this state (different account + bucket).
#
# 1. In the PRODUCTION Vultr account, create an Object Storage subscription.
# 2. Copy this file:  cp backend-prod.hcl.example backend.hcl
# 3. Fill in bucket + endpoints.s3 (region-specific hostname).
# 4. Export that account's Object Storage S3 keys, then:
#      terraform init -reconfigure -backend-config=backend.hcl
#
# backend.hcl is gitignored — never commit it.
# =============================================================================

bucket    = "flylive-audio-tfstate-production"
endpoints = { s3 = "https://REGION.vultrobjects.com" }
